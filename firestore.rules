rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper to check if request is from the owner
    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // Users collection
    match /users/{uid} {
      allow read: if true;
      allow write: if isOwner(uid);
    }

    // CreatorProfiles collection
    match /creatorProfiles/{uid} {
      allow read: if true;
      allow write: if isOwner(uid);
    }

    // BrandProfiles collection
    match /brandProfiles/{uid} {
      allow read: if true;
      allow write: if isOwner(uid);
    }

    // ATIScores collection: client-side write blocked, server action only
    match /atiScores/{creatorUid} {
      allow read: if true;
      allow write: if false; 
    }

    // Deals collection
    match /deals/{dealId} {
      allow read: if isAuthenticated() && (
        resource.data.creatorUid == request.auth.uid ||
        resource.data.brandUid == request.auth.uid
      );
      allow create: if isAuthenticated() && (
        request.resource.data.creatorUid == request.auth.uid ||
        request.resource.data.brandUid == request.auth.uid
      );
      allow update: if isAuthenticated() && (
        resource.data.creatorUid == request.auth.uid ||
        resource.data.brandUid == request.auth.uid
      );
      allow delete: if false;

      // Messages subcollection
      match /messages/{messageId} {
        allow read: if isAuthenticated() && (
          get(/databases/$(database)/documents/deals/$(dealId)).data.creatorUid == request.auth.uid ||
          get(/databases/$(database)/documents/deals/$(dealId)).data.brandUid == request.auth.uid
        );
        allow create: if isAuthenticated() && (
          get(/databases/$(database)/documents/deals/$(dealId)).data.creatorUid == request.auth.uid ||
          get(/databases/$(database)/documents/deals/$(dealId)).data.brandUid == request.auth.uid
        ) && request.resource.data.senderUid == request.auth.uid;
        allow update, delete: if false;
      }
    }

    // Past collaborations
    match /pastCollaborations/{id} {
      allow read: if true;
      allow write: if isAuthenticated() && request.resource.data.creatorUid == request.auth.uid;
    }

    // Mock engagement data (not editable by users, server only)
    match /mockEngagementData/{creatorUid} {
      allow read: if true;
      allow write: if false;
    }
  }
}
